---
import Layout from '../../layouts/Layout.astro';
import { QRGenerator } from '../../components/tools/QRGenerator';
import { getLocaleFromPath, getTranslations } from '../../i18n/utils';

const locale = getLocaleFromPath(Astro.url.pathname);
const t = getTranslations(locale);
---

<Layout title={t.qrPageTitle} description={t.qrPageDescription}>
  <section class="border-b border-border bg-bg">
    <div class="mx-auto flex max-w-[1400px] flex-col gap-3 px-4 py-10 md:flex-row md:items-center md:justify-between md:px-6 md:py-12">
      <div>
        <p class="mb-2 font-mono text-xs uppercase tracking-[0.2em] text-accent">{t.qrPageBreadcrumb}</p>
        <h1 class="font-display text-2xl font-semibold tracking-tight text-text md:text-4xl lg:text-5xl">
          {t.qrPageTitle}
        </h1>
        <p class="mt-2 max-w-xl text-sm text-text-soft md:text-base">{t.qrPageDescription}</p>
      </div>
      <a
        href={locale === 'en' ? '/' : '/es/'}
        class="inline-flex items-center gap-2 self-start border border-border px-4 py-2 font-mono text-xs uppercase tracking-wider text-text-soft transition-colors hover:border-accent hover:text-accent"
      >
        <svg width="16" height="16" viewBox="0 0 24 24" fill="none" stroke="currentColor" stroke-width="1.5" stroke-linecap="round" stroke-linejoin="round">
          <path d="M19 12H5" />
          <path d="M12 19l-7-7 7-7" />
        </svg>
        {t.backToTools}
      </a>
    </div>
  </section>

  <section class="mx-auto max-w-[1400px] px-4 py-10 md:px-6 md:py-16">
    <QRGenerator client:load locale={locale} />
  </section>
</Layout>
