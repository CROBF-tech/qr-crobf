{
  "extends": "./base.json",
  "compilerOptions": {
    "allowArbitraryExtensions": true,
    "jsx": "react-jsx",
    "jsxImportSource": "astro",
    "baseUrl": ".",
    "paths": {
      "@/*": ["./src/*"]
    }
  },
  "include": ["src/**/*", "**/*.ts", "**/*.tsx", "**/*.astro", ".astro/types.d.ts"],
  "exclude": ["dist", "node_modules"]
}
